@model SkillMatrix.Core.ViewModels.ConsultantListViewModel

@{
    ViewData["Title"] = "Catalogue des Experts";
    Layout = "_Layout";

    var currentSearch = ViewData["CurrentSearch"]?.ToString();
}

<div class="container py-5 consultant-page">
    <div class="text-center consultant-hero mb-5">
        <h1 class="fw-bold consultant-page-title">Nos Consultants Experts</h1>
        <p class="text-muted consultant-page-subtitle">
            Explorez nos talents disponibles pour vos projets stratégiques.
        </p>
    </div>

    <div class="row mb-4">
        <div class="col-lg-8 mx-auto">
            <form method="get" asp-controller="Home" asp-action="ConsultantsList">
                <div class="input-group input-group-lg shadow-sm consultant-search-box">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="bi bi-search text-primary"></i>
                    </span>
                    <input type="text"
                           name="searchQuery"
                           class="form-control border-start-0 ps-0"
                           placeholder="Compétence, métier, outil..."
                           value="@currentSearch" />
                    <button class="btn btn-primary px-4" type="submit">Trouver</button>
                </div>

                @if (!string.IsNullOrWhiteSpace(currentSearch))
                {
                    <div class="text-center mt-2">
                        <a asp-action="ConsultantsList"
                           class="text-decoration-none small text-secondary consultant-reset-link">
                            <i class="bi bi-x-circle"></i> Réinitialiser la recherche
                        </a>
                    </div>
                }
            </form>
        </div>
    </div>

    <div class="consultant-results-summary mb-4 text-center">
        @if (!string.IsNullOrWhiteSpace(currentSearch))
        {
            <p class="mb-1">
                <strong>@Model.TotalCount</strong> résultat(s) pour
                <span class="consultant-search-highlight">"@currentSearch"</span>
            </p>
        }
        else
        {
            <p class="mb-1">
                <strong>@Model.TotalCount</strong> consultant(s) disponible(s) dans le catalogue
            </p>
        }

        @if (Model.TotalPages > 1)
        {
            <small class="text-muted">
                Page @Model.CurrentPage sur @Model.TotalPages
            </small>
        }
    </div>

    @if (Model.Consultants == null || !Model.Consultants.Any())
    {
        <div class="consultant-empty-state text-center">
            <div class="consultant-empty-icon mb-3">
                <i class="bi bi-search"></i>
            </div>
            <h3 class="fw-bold mb-2">Aucun consultant trouvé</h3>
            <p class="text-muted mb-3">
                Essayez un autre mot-clé ou réinitialisez la recherche.
            </p>
            <a asp-action="ConsultantsList" class="btn btn-outline-primary rounded-pill px-4">
                Voir tout le catalogue
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var consultant in Model.Consultants)
            {
                var statusClass = consultant.Statut switch
                {
                    "Disponible" => "status-disponible",
                    "Intercontrat" => "status-intercontrat",
                    "En Mission" => "status-en-mission",
                    _ => "status-default"
                };

                var initial = !string.IsNullOrWhiteSpace(consultant.NomComplet)
                    ? consultant.NomComplet.Trim()[0].ToString().ToUpper()
                    : "?";

                <div class="col-md-6 col-xl-4">
                    <div class="card consultant-card-modern h-100 border-0 shadow-sm">
                        <div class="card-body p-4 d-flex flex-column">
                            <div class="d-flex align-items-start mb-3">
                                <div class="avatar-circle-sm consultant-avatar me-3">
                                    @initial
                                </div>

                                <div class="flex-grow-1">
                                    <h5 class="card-title mb-1 fw-bold consultant-name">
                                        @consultant.NomComplet
                                    </h5>
                                    <div class="consultant-title text-muted">
                                        @consultant.Titre
                                    </div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <span class="consultant-status-badge @statusClass">
                                    @consultant.Statut
                                </span>
                            </div>

                            <div class="consultant-skills mb-4">
                                @if (consultant.Competences != null && consultant.Competences.Any())
                                {
                                    foreach (var skill in consultant.Competences.Take(3))
                                    {
                                        <span class="skill-badge">@skill</span>
                                    }

                                    @if (consultant.Competences.Count > 3)
                                    {
                                        <span class="consultant-skill-more">
                                            +@(consultant.Competences.Count - 3)
                                        </span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted small">Aucune compétence renseignée</span>
                                }
                            </div>

                            <div class="mt-auto d-grid gap-2">
                                <a asp-action="Details"
                                   asp-route-id="@consultant.Id"
                                   class="btn btn-outline-primary consultant-action-btn">
                                    <i class="bi bi-eye me-1"></i> Voir le profil
                                </a>

                                <a asp-action="DownloadCv"
                                   asp-route-id="@consultant.Id"
                                   class="btn btn-light consultant-cv-btn">
                                    <i class="bi bi-file-earmark-pdf me-1"></i> Télécharger CV
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-5">
            <ul class="pagination justify-content-center consultant-pagination">
                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="ConsultantsList"
                       asp-route-page="@(Model.CurrentPage - 1)"
                       asp-route-searchQuery="@currentSearch">
                        Précédent
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="ConsultantsList"
                           asp-route-page="@i"
                           asp-route-searchQuery="@currentSearch">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="ConsultantsList"
                       asp-route-page="@(Model.CurrentPage + 1)"
                       asp-route-searchQuery="@currentSearch">
                        Suivant
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>