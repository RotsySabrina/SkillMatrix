@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Connexion";
    var appName = "TalentTris";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="auth-page">
    <div class="auth-card auth-card-refined">

        <div class="auth-visual-panel">
            <div class="auth-visual-overlay"></div>
        </div>

        <div class="auth-form-panel">
            <div class="auth-form-shell">
                <div class="auth-form-header">
                    <h1 class="auth-title">@appName</h1>
                    <p class="auth-subtitle">Accédez à votre espace @appName</p>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger auth-alert" role="alert">
                        @ViewBag.Error
                    </div>
                }

                <form asp-action="Login" method="post" class="auth-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@returnUrl" />

                    <div class="auth-field">
                        <label for="email" class="form-label auth-label">Adresse email</label>
                        <input type="email"
                               id="email"
                               name="email"
                               class="form-control auth-input"
                               placeholder="admin@talenttris.com"
                               autocomplete="username"
                               required />
                    </div>

                    <div class="auth-field">
                        <label for="password" class="form-label auth-label">Mot de passe</label>
                        <input type="password"
                               id="password"
                               name="password"
                               class="form-control auth-input"
                               placeholder="Entrez votre mot de passe"
                               autocomplete="current-password"
                               required />
                    </div>

                    <button type="submit" class="btn auth-submit-btn w-100">
                        Se connecter
                    </button>
                </form>

            </div>
        </div>

    </div>
</div>