@model SkillMatrix.Core.Models.Consultant

@{
    ViewData["Title"] = $"Profil de {Model.Prenom} {Model.Nom}";
}

<div class="container py-5">
    
    @* Bouton Retour *@
    <div class="mb-4">
        <a asp-action="ConsultantsList" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Retour au catalogue
        </a>
        <a asp-action="DownloadCv" asp-route-id="@Model.Id" class="btn btn-danger float-end">
            <i class="bi bi-file-pdf"></i> Télécharger en PDF
        </a>
    </div>

    <div class="card shadow-lg border-0 overflow-hidden">
        
        @* 1. EN-TÊTE DU CV *@
        <div class="bg-primary text-white p-5">
            <div class="row align-items-center">
                <div class="col-md-2 text-center">
                    <div class="bg-white text-primary rounded-circle d-flex align-items-center justify-content-center mx-auto" style="width: 100px; height: 100px; font-size: 2.5rem; font-weight: bold;">
                        @Model.Prenom.Substring(0,1)@Model.Nom.Substring(0,1)
                    </div>
                </div>
                <div class="col-md-10">
                    <h1 class="display-5 fw-bold">@Model.Prenom @Model.Nom</h1>
                    <h3 class="fw-light opacity-75">@Model.Titre</h3>
                    <div class="mt-3">
                        <span class="badge bg-light text-primary me-2">@Model.ExperienceTotale ans d'expérience</span>
                        <span class="badge @(Model.Statut == "Intercontrat" ? "bg-success" : "bg-warning")">
                            @Model.Statut
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="row g-0">
                
                @* 2. COLONNE GAUCHE : SKILLS & INFOS *@
                <div class="col-md-4 bg-light p-5 border-end">
                    
                    <hr class="my-4">

                    <h5 class="text-uppercase text-primary fw-bold mb-4">Compétences</h5>
                    @if (Model.ConsultantSkills.Any())
                    {
                        foreach (var skill in Model.ConsultantSkills.OrderByDescending(s => s.Niveau))
                        {
                            <div class="mb-3">
                                <div class="d-flex justify-content-between">
                                    <span class="fw-bold">@skill.Skill.Nom</span>
                                    <span class="text-muted small">Niv. @skill.Niveau</span>
                                </div>
                                <div class="progress" style="height: 6px;">
                                    @* Calcul du pourcentage : Niveau 1-5 converti en 20-100% *@
                                    <div class="progress-bar bg-primary" role="progressbar" style="width: @(skill.Niveau * 20)%"></div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted fst-italic">Aucune compétence listée.</p>
                    }
                </div>

                @* Section Expériences *@
                <div class="col-md-8 p-5 bg-white">
                    <h4 class="text-uppercase text-primary fw-bold mb-4">
                        <i class="bi bi-briefcase me-2"></i> Expériences Professionnelles
                    </h4>

                    @if (Model.Missions != null && Model.Missions.Any())
                    {
                        <div class="timeline">
                            @foreach (var mission in Model.Missions)
                            {
                                <div class="mb-5 position-relative ps-4 border-start border-3 border-light">
                                    <div class="position-absolute top-0 start-0 translate-middle bg-primary rounded-circle" style="width: 12px; height: 12px;"></div>
                                    
                                    <h5 class="fw-bold text-dark mb-1">@mission.TitreProjet</h5>
                                    <div class="text-primary fw-bold mb-2">
                                        @mission.Client?.Nom @* Nom du Client/Entreprise *@
                                        <span class="text-muted fw-normal ms-2">
                                            | @(string.IsNullOrEmpty(mission.RoleOccupe) ? "" : mission.RoleOccupe + " |") 
                                            @mission.DateDebut.ToString("MMM yyyy") - 
                                            @(mission.DateFin.HasValue ? mission.DateFin.Value.ToString("MMM yyyy") : "Aujourd'hui")
                                        </span>
                                    </div>
                                    <p class="text-secondary mt-2" style="white-space: pre-line;">
                                        @mission.Description
                                    </p>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-light">Aucune mission enregistrée.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>