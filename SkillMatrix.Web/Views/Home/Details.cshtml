@model SkillMatrix.Core.Models.Consultant

@{
    ViewData["Title"] = $"Profil de {Model.Prenom} {Model.Nom}";

    var fullName = $"{Model.Prenom} {Model.Nom}".Trim();
    var firstInitial = !string.IsNullOrWhiteSpace(Model.Prenom) ? Model.Prenom.Trim()[0].ToString().ToUpper() : "";
    var lastInitial = !string.IsNullOrWhiteSpace(Model.Nom) ? Model.Nom.Trim()[0].ToString().ToUpper() : "";
    var initials = string.IsNullOrWhiteSpace(firstInitial + lastInitial) ? "?" : firstInitial + lastInitial;

    var skillCount = Model.ConsultantSkills?.Count ?? 0;
    var missionCount = Model.Missions?.Count ?? 0;

    var statusClass = Model.Statut switch
    {
        "Disponible" => "detail-status-disponible",
        "En Mission" => "detail-status-mission",
        "Intercontrat" => "detail-status-intercontrat",
        _ => "detail-status-default"
    };
}

<div class="container py-5 consultant-detail-page">

    <div class="consultant-detail-topbar mb-4">
        <a asp-action="ConsultantsList" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i> Retour au catalogue
        </a>

        <a asp-action="DownloadCv" asp-route-id="@Model.Id" class="btn btn-danger rounded-pill px-4">
            <i class="bi bi-file-earmark-pdf me-1"></i> Télécharger en PDF
        </a>
    </div>

    <div class="card consultant-detail-card border-0 shadow-sm overflow-hidden">
        <div class="consultant-detail-hero">
            <div class="row align-items-center g-4">
                <div class="col-lg-2 text-center text-lg-start">
                    <div class="consultant-detail-avatar mx-auto mx-lg-0">
                        @initials
                    </div>
                </div>

                <div class="col-lg-10">
                    <h1 class="consultant-detail-name mb-2">@fullName</h1>
                    <div class="consultant-detail-title mb-3">@Model.Titre</div>

                    <div class="consultant-detail-badges mb-4">
                        <span class="consultant-detail-pill">
                            @Model.ExperienceTotale an(s) d’expérience
                        </span>

                        <span class="consultant-detail-pill @statusClass">
                            @Model.Statut
                        </span>
                    </div>

                    <div class="row g-3 consultant-detail-metrics">
                        <div class="col-sm-4">
                            <div class="consultant-detail-metric-box">
                                <div class="consultant-detail-metric-value">@skillCount</div>
                                <div class="consultant-detail-metric-label">Compétence(s)</div>
                            </div>
                        </div>

                        <div class="col-sm-4">
                            <div class="consultant-detail-metric-box">
                                <div class="consultant-detail-metric-value">@missionCount</div>
                                <div class="consultant-detail-metric-label">Mission(s)</div>
                            </div>
                        </div>

                        <div class="col-sm-4">
                            <div class="consultant-detail-metric-box">
                                <div class="consultant-detail-metric-value">#@Model.Id</div>
                                <div class="consultant-detail-metric-label">Référence profil</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="row g-0">
                <div class="col-lg-4 consultant-detail-sidebar">
                    <div class="consultant-detail-section">
                        <h5 class="consultant-detail-section-title">Compétences</h5>

                        @if (Model.ConsultantSkills != null && Model.ConsultantSkills.Any())
                        {
                            foreach (var skill in Model.ConsultantSkills.OrderByDescending(s => s.Niveau))
                            {
                                <div class="consultant-skill-row">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="fw-bold">@((skill.Skill?.Nom) ?? "Compétence inconnue")</span>
                                        <span class="text-muted small">Niv. @skill.Niveau</span>
                                    </div>

                                    <div class="progress consultant-skill-progress">
                                        <div class="progress-bar bg-primary"
                                             role="progressbar"
                                             style="width: @(skill.Niveau * 20)%">
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="consultant-empty-box">
                                Aucune compétence renseignée.
                            </div>
                        }
                    </div>
                </div>

                <div class="col-lg-8 consultant-detail-main">
                    <div class="consultant-detail-section">
                        <h4 class="consultant-detail-main-title">
                            <i class="bi bi-briefcase me-2"></i>Expériences professionnelles
                        </h4>

                        @if (Model.Missions != null && Model.Missions.Any())
                        {
                            <div class="consultant-mission-timeline">
                                @foreach (var mission in Model.Missions)
                                {
                                    <div class="consultant-mission-item">
                                        <div class="consultant-mission-dot"></div>

                                        <div class="consultant-mission-content">
                                            <h5 class="consultant-mission-title mb-1">@mission.TitreProjet</h5>

                                            <div class="consultant-mission-meta mb-2">
                                                <span class="fw-semibold text-primary">@mission.Client?.Nom</span>
                                                <span class="mx-2">•</span>
                                                <span>@(string.IsNullOrWhiteSpace(mission.RoleOccupe) ? "Rôle non précisé" : mission.RoleOccupe)</span>
                                            </div>

                                            <div class="consultant-mission-dates mb-2">
                                                @mission.DateDebut.ToString("MMM yyyy")
                                                -
                                                @(mission.DateFin.HasValue ? mission.DateFin.Value.ToString("MMM yyyy") : "Aujourd’hui")
                                            </div>

                                            @if (!string.IsNullOrWhiteSpace(mission.Description))
                                            {
                                                <p class="consultant-mission-description mb-0">
                                                    @mission.Description
                                                </p>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="consultant-empty-box">
                                Aucune mission enregistrée pour ce consultant.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>