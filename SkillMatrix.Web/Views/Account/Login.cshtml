<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card shadow border-0">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="bi bi-shield-lock text-primary" style="font-size: 3rem;"></i>
                        <h3 class="fw-bold mt-2">SkillMatrix</h3>
                        <p class="text-muted">Connexion à votre espace</p>
                    </div>

                    @if (ViewBag.Error != null) {
                        <div class="alert alert-danger small">@ViewBag.Error</div>
                    }

                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-uppercase">Email</label>
                            <input type="email" name="email" class="form-control rounded-pill" required />
                        </div>
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-uppercase">Mot de passe</label>
                            <input type="password" name="password" class="form-control rounded-pill" required />
                        </div>
                        <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 shadow-sm">
                            Se connecter
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>