@{
    ViewData["Title"] = "Erreur Système";
}

<div class="container mt-5 pt-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <i class="bi bi-exclamation-triangle text-danger" style="font-size: 5rem;"></i>
            <h1 class="display-4 fw-bold mt-3">Oups !</h1>
            <p class="lead text-muted">Une erreur inattendue est survenue dans l'application SkillMatrix.</p>
            <div class="alert alert-light border mt-4">
                <small class="text-secondary text-break">
                    Si le problème persiste, veuillez contacter l'administrateur avec le code d'erreur : 
                    <code>@Context.TraceIdentifier</code>
                </small>
            </div>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill px-4 mt-3">
                Retour à l'accueil
            </a>
        </div>
    </div>
</div>