@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString();

    var currentUser = User?.Identity?.IsAuthenticated == true
        ? User.Identity!.Name ?? "Utilisateur"
        : "Utilisateur";

    var userInitial = !string.IsNullOrWhiteSpace(currentUser)
        ? currentUser.Trim()[0].ToString().ToUpper()
        : "T";

    bool isHomeActive = currentController == "Home" && (currentAction == "Index" || currentAction == "UserHome");
    bool isConsultantsActive = currentController == "Home" && currentAction == "ConsultantsList";
    bool isTimelineActive = currentPage == "/Dashboard/Timeline";
    bool isAdminDataActive =
        currentPage != null &&
        (currentPage.StartsWith("/Consultants") || currentPage.StartsWith("/Skills"));
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TalentTris</title>

    <link rel="stylesheet" href="~/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="tt-app-shell">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark tt-navbar">
            <div class="container-fluid px-4">
                <a class="navbar-brand tt-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="tt-brand-name">TalentTris</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#ttMainNav"
                        aria-controls="ttMainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="ttMainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 tt-nav-links">
                        <li class="nav-item">
                            @if (User?.Identity?.IsAuthenticated == true && !User.IsInRole("Admin"))
                            {
                                <a class="nav-link @(isHomeActive ? "active" : "")"
                                asp-area="" asp-controller="Home" asp-action="UserHome">
                                    Accueil
                                </a>
                            }
                            else
                            {
                                <a class="nav-link @(isHomeActive ? "active" : "")"
                                asp-area="" asp-controller="Home" asp-action="Index">
                                    Accueil
                                </a>
                            }
                        </li>

                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(isConsultantsActive ? "active" : "")"
                                   asp-area="" asp-controller="Home" asp-action="ConsultantsList">
                                    Consultants
                                </a>
                            </li>

                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle @(isAdminDataActive ? "active" : "")"
                                       href="#"
                                       id="ttDataDropdown"
                                       role="button"
                                       data-bs-toggle="dropdown"
                                       aria-expanded="false">
                                        Gestion des données
                                    </a>
                                    <ul class="dropdown-menu tt-dropdown-menu" aria-labelledby="ttDataDropdown">
                                        <li>
                                            <a class="dropdown-item" asp-area="Admin" asp-page="/Consultants/Index">
                                                Gestion consultants
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-area="Admin" asp-page="/Consultants/Create">
                                                Ajouter un consultant
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-area="Admin" asp-page="/Consultants/Import">
                                                Import CSV
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-area="Admin" asp-page="/Skills/Index">
                                                Gestion compétences
                                            </a>
                                        </li>
                                    </ul>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link @(isTimelineActive ? "active" : "")"
                                       asp-area="Admin" asp-page="/Dashboard/Timeline">
                                        Timeline
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        <div class="tt-user-menu dropdown">
                            <button class="btn tt-user-button dropdown-toggle"
                                    type="button"
                                    id="ttUserDropdown"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                <span class="tt-user-avatar">@userInitial</span>
                                <span class="tt-user-name">@currentUser</span>
                            </button>

                            <ul class="dropdown-menu dropdown-menu-end tt-dropdown-menu" aria-labelledby="ttUserDropdown">
                                <li>
                                    <span class="dropdown-item-text tt-user-role">Connecté</span>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                @if (User.IsInRole("Admin"))
                                {
                                    <a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="Index">
                                        Tableau de bord
                                    </a>
                                }
                                else
                                {
                                    <a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="UserHome">
                                        Accueil utilisateur
                                    </a>
                                }
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="Logout">
                                        Déconnexion
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <div class="ms-lg-3">
                            <a class="btn btn-light btn-sm rounded-pill px-4"
                               asp-area="" asp-controller="Account" asp-action="Login">
                                Connexion
                            </a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="tt-page-wrapper">
        <main class="tt-main-content container-fluid px-4 py-4">
            @RenderBody()
        </main>
    </div>

    <footer class="tt-footer">
        <div class="container-fluid px-4">
            <div class="tt-footer-inner">
                <div class="tt-footer-left">
                    © 2026 TalentTris — Smart staffing & consulting workspace
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>