@{
    ViewData["Title"] = "Tableau de Bord";
}

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold">Bienvenue sur SkillMatrix</h2>
            <p class="text-muted">Plateforme de gestion et recherche de compétences.</p>
        </div>
    </div>

    <div class="row g-4">
        @if (User.IsInRole("Admin"))
        {
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm bg-primary text-white">
                    <div class="card-body">
                        <h5>Gestion</h5>
                        <p class="small opacity-75">Administrez les profils et les référentiels techniques.</p>
                        <a asp-area="Admin" asp-page="/Consultants/Index" class="btn btn-light btn-sm mt-3">Accéder</a>
                    </div>
                </div>
            </div>
        }

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="text-primary">Recherche Rapide</h5>
                    <p class="text-muted small">Trouvez un consultant par compétence ou par nom.</p>
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-outline-primary btn-sm mt-3">Chercher</a>
                </div>
            </div>
        </div>
    </div>
</div>