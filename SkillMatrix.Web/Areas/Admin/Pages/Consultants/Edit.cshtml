@page
@model SkillMatrix.Web.Areas_Admin_Pages_Consultants.EditModel

@{
    ViewData["Title"] = "Modifier Consultant";

    var statusClass = Model.Consultant.Statut switch
    {
        "Disponible" => "bg-info text-white",
        "En Mission" => "bg-success",
        "Intercontrat" => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}

<div class="container pb-5 admin-edit-page">
    <div class="mb-4">
        <h1 class="fw-bold mb-1">Modifier le profil</h1>
        <h4 class="text-muted mb-0">@Model.Consultant.Prenom @Model.Consultant.Nom</h4>
    </div>

    <form method="post">
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 admin-edit-card mb-4">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0">Informations générales</h5>
                    </div>

                    <div class="card-body">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Consultant.Id" />

                        <div class="mb-3">
                            <label asp-for="Consultant.Nom" class="form-label fw-bold"></label>
                            <input asp-for="Consultant.Nom" class="form-control" />
                            <span asp-validation-for="Consultant.Nom" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Consultant.Prenom" class="form-label fw-bold"></label>
                            <input asp-for="Consultant.Prenom" class="form-control" />
                            <span asp-validation-for="Consultant.Prenom" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Consultant.Titre" class="form-label fw-bold"></label>
                            <input asp-for="Consultant.Titre" class="form-control" placeholder="ex: Développeur Fullstack" />
                            <span asp-validation-for="Consultant.Titre" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Consultant.ExperienceTotale" class="form-label fw-bold">Expérience (ans)</label>
                            <input asp-for="Consultant.ExperienceTotale" class="form-control" type="number" />
                            <span asp-validation-for="Consultant.ExperienceTotale" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Statut actuel</label>
                            <div>
                                <span class="badge rounded-pill px-3 py-2 @statusClass">
                                    @Model.Consultant.Statut
                                </span>
                            </div>
                            <div class="small text-muted mt-2">
                                Le statut est calculé automatiquement à partir des missions déjà enregistrées.
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm border-0 admin-edit-card mb-4">
                    <div class="card-header bg-white">
                        <h5 class="mb-0 fw-bold">
                            <i class="bi bi-star-fill me-2 text-warning"></i>Compétences & Niveaux
                        </h5>
                    </div>

                    <div class="card-body p-0">
                        <div class="list-group list-group-flush edit-skills-list">
                            @for (int i = 0; i < Model.AssignedSkills.Count; i++)
                            {
                                <div class="list-group-item py-3">
                                    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">
                                        <div class="form-check">
                                            <input type="checkbox"
                                                   name="selectedSkills"
                                                   value="@Model.AssignedSkills[i].SkillId"
                                                   id="skill_@Model.AssignedSkills[i].SkillId"
                                                   class="form-check-input skill-checkbox"
                                                   @(Model.AssignedSkills[i].Assigned ? "checked" : null) />
                                            <label class="form-check-label fw-medium" for="skill_@Model.AssignedSkills[i].SkillId">
                                                @Model.AssignedSkills[i].Name
                                            </label>
                                        </div>

                                        <div class="d-flex align-items-center">
                                            <small class="text-muted me-2">Niveau :</small>
                                            <input type="range"
                                                   class="form-range skill-level-range"
                                                   name="SkillLevels[@Model.AssignedSkills[i].SkillId]"
                                                   value="@(Model.AssignedSkills[i].Level ?? 1)"
                                                   min="1" max="5"
                                                   style="width: 90px;"
                                                   oninput="this.nextElementSibling.value = this.value" />
                                            <output class="badge bg-primary ms-2">@(Model.AssignedSkills[i].Level ?? 1)</output>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="card-footer bg-light text-center py-2">
                        <small class="text-muted">Cochez les compétences possédées par le consultant.</small>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check2-circle me-1"></i> Enregistrer les modifications
                    </button>

                    <a asp-page="./Index" class="btn btn-outline-secondary">
                        Retour à la liste
                    </a>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                    <div>
                        <h4 class="mb-1">Parcours professionnel</h4>
                        <p class="text-muted mb-0">
                            Les missions sont affichées ici en lecture seule pour éviter
                            de mélanger la gestion du profil et l’historique professionnel.
                        </p>
                    </div>
                </div>

                @if (Model.ExistingMissions != null && Model.ExistingMissions.Any())
                {
                    <div class="d-grid gap-3">
                        @foreach (var mission in Model.ExistingMissions)
                        {
                            <div class="card border-0 shadow-sm mission-readonly-card">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
                                        <div>
                                            <h5 class="mb-1 fw-bold">@mission.TitreProjet</h5>
                                            <div class="text-muted small">
                                                @(mission.Client?.Nom ?? "Client non renseigné")
                                            </div>
                                        </div>

                                        <span class="badge bg-light text-dark border">
                                            ID mission : @mission.Id
                                        </span>
                                    </div>

                                    <div class="row g-3 small">
                                        <div class="col-md-4">
                                            <div class="text-muted">Date début</div>
                                            <div class="fw-semibold">@mission.DateDebut.ToString("dd/MM/yyyy")</div>
                                        </div>

                                        <div class="col-md-4">
                                            <div class="text-muted">Date fin</div>
                                            <div class="fw-semibold">
                                                @(mission.DateFin.HasValue ? mission.DateFin.Value.ToString("dd/MM/yyyy") : "En cours")
                                            </div>
                                        </div>

                                        <div class="col-md-4">
                                            <div class="text-muted">Rôle</div>
                                            <div class="fw-semibold">
                                                @(string.IsNullOrWhiteSpace(mission.RoleOccupe) ? "Non renseigné" : mission.RoleOccupe)
                                            </div>
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(mission.Description))
                                        {
                                            <div class="col-12">
                                                <div class="text-muted">Description</div>
                                                <div class="mission-description-readonly">
                                                    @mission.Description
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-light border rounded-4">
                        Aucune mission enregistrée pour ce consultant.
                    </div>
                }
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}