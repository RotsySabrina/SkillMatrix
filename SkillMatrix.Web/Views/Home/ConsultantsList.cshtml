@model SkillMatrix.Core.ViewModels.ConsultantListViewModel

@{
    ViewData["Title"] = "Catalogue des Experts";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold">Nos Consultants Experts</h1>
        <p class="text-muted">Explorez nos talents disponibles pour vos projets stratégiques.</p>
    </div>

    @* BARRE DE RECHERCHE*@
    <div class="row mb-5">
        <div class="col-md-8 mx-auto">
            <form method="get" asp-controller="Home" asp-action="ConsultantsList">
                <div class="input-group input-group-lg shadow-sm">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-primary"></i></span>
                    <input type="text" name="searchQuery" class="form-control border-start-0 ps-0" 
                           placeholder="Compétence, métier, outil..." 
                           value="@ViewData["CurrentSearch"]">
                    <button class="btn btn-primary px-4" type="submit">Trouver</button>
                </div>
                @if (ViewData["CurrentSearch"] != null)
                {
                    <div class="text-center mt-2">
                        <a asp-action="ConsultantsList" class="text-decoration-none small text-secondary">
                            <i class="bi bi-x-circle"></i> Réinitialiser les filtres
                        </a>
                    </div>
                }
            </form>
        </div>
    </div>

    @* 🗂️ GRILLE DE RESULTATS *@
    <div class="row">
        @foreach (var consultant in Model.Consultants)
{
    // Logique de couleur de badge selon le statut réel
    var statusClass = consultant.Statut switch
    {
        "Disponible" => "bg-success",
        "Intercontrat" => "bg-info",
        "En Mission" => "bg-secondary",
        _ => "bg-dark"
    };

    <div class="col-md-4 mb-4">
        <div class="card h-100 border-0 shadow-sm hover-shadow transition">
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="avatar-circle-sm bg-primary bg-opacity-10 text-primary me-3">
                        @consultant.NomComplet.Substring(0, 1)
                    </div>
                    <div>
                        <h5 class="card-title mb-0 fw-bold">@consultant.NomComplet</h5>
                        <small class="text-muted">@consultant.Titre</small>
                    </div>
                </div>

                @* Statut Dynamique *@
                <span class="badge @statusClass mb-3">@consultant.Statut</span>

                @* Compétences Dynamiques (On affiche les 3 premières) *@
                <div class="mb-3">
                    @if (consultant.Competences != null && consultant.Competences.Any())
                    {
                        foreach (var skill in consultant.Competences.Take(3))
                        {
                            <span class="badge bg-light text-dark border me-1">@skill</span>
                        }
                        @if (consultant.Competences.Count > 3)
                        {
                            <span class="text-muted small">+@(consultant.Competences.Count - 3)</span>
                        }
                    }
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 p-4 pt-0">
                <div class="d-grid gap-2">
                    <a asp-action="Details" asp-route-id="@consultant.Id" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-eye me-1"></i> Voir le profil
                    </a>
                    <a asp-action="DownloadCv" asp-route-id="@consultant.Id" class="btn btn-link btn-sm text-danger text-decoration-none">
                        <i class="bi bi-file-pdf"></i> Télécharger CV
                    </a>
                </div>
            </div>
        </div>
    </div>
        }
    </div>

    @* 📑 PAGINATION *@
    @if (Model.TotalPages > 1)
    {
        <nav class="mt-5">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="ConsultantsList" asp-route-page="@(Model.CurrentPage - 1)">Précédent</a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="ConsultantsList" asp-route-page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="ConsultantsList" asp-route-page="@(Model.CurrentPage + 1)">Suivant</a>
                </li>
            </ul>
        </nav>
    }
</div>

<style>
    .transition { transition: all 0.3s ease; }
    .hover-shadow:hover { transform: translateY(-5px); box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.1)!important; }
    .avatar-circle-sm { 
        width: 45px; height: 45px; border-radius: 50%; 
        display: flex; align-items: center; justify-content: center; font-weight: bold;
    }
</style>