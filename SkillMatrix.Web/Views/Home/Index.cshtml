@{
    ViewData["Title"] = "Tableau de Bord";
}

<div class="container py-4">
    <div class="row mb-4">
        <div class="col">
            <h2 class="fw-bold text-dark">Tableau de Bord</h2>
            <p class="text-muted">Aperçu en temps réel des ressources SkillMatrix.</p>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white p-3 h-100">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase small opacity-75">Consultants</h6>
                        <h2 class="mb-0 fw-bold">@Model.TotalConsultants</h2>
                    </div>
                    <i class="bi bi-people fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm border-start border-success border-4 p-3 h-100">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase text-muted small">En Mission</h6>
                        <h2 class="mb-0 fw-bold text-success">@Model.EnMissionCount</h2>
                    </div>
                    <i class="bi bi-briefcase text-success fs-1 opacity-25"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm border-start border-warning border-4 p-3 h-100">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase text-muted small">Intercontrat</h6>
                        <h2 class="mb-0 fw-bold text-warning">@Model.IntercontratCount</h2>
                    </div>
                    <i class="bi bi-clock-history text-warning fs-1 opacity-25"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm border-start border-info border-4 p-3 h-100">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase text-muted small">Disponibles</h6>
                        <h2 class="mb-0 fw-bold text-info">@Model.DisponibleCount</h2>
                    </div>
                    <i class="bi bi-check-circle text-info fs-1 opacity-25"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold">Compétences Clés</h6>
                </div>
                <div class="card-body">
                    @foreach(var skill in Model.TopSkills)
                    {
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="small fw-semibold">@skill.SkillNom</span>
                                <span class="small text-muted">@skill.Count profils</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                @{ var percent = (skill.Count * 100) / (Model.TotalConsultants > 0 ? Model.TotalConsultants : 1); }
                                <div class="progress-bar bg-primary" style="width: @percent%"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100 bg-light">
                <div class="card-body d-flex flex-column justify-content-center text-center p-5">
                    <i class="bi bi-search text-primary mb-3" style="font-size: 3rem;"></i>
                    <h4>Besoin d'un expert ?</h4>
                    <p class="text-muted">Utilisez le moteur de recherche Elasticsearch pour trouver le profil idéal.</p>
                    <a asp-action="ConsultantsList" class="btn btn-primary rounded-pill px-4 align-self-center mt-2">
                        Lancer une recherche
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>